# KernelSU Action 编译配置文件
# 用于为小米10S (thyme) 编译支持 EROFS + KernelSU 的内核
# 基于 crDroid 14.0 内核源码

# === 内核源码 ===
KERNEL_SOURCE=https://github.com/crdroidandroid/android_kernel_xiaomi_thyme
KERNEL_SOURCE_BRANCH=14.0
KERNEL_CONFIG=thyme_defconfig
KERNEL_IMAGE_NAME=Image
ARCH=arm64

# === 编译方案 ===
# 'A' = clang+gcc 编译
METHOD_OK=A

# === 编译器选择 ===
# true = 使用自定义 Clang (AOSP r445002 = clang-14)
USE_CUSTOM_CLANG=true
CUT_PYTHON=false

# 自定义 Clang 源码
CUSTOM_CLANG_SOURCE=https://github.com/AOSP-12/prebuilts_clang_host_linux-x86_clang-r445002.git
CUSTOM_CLANG_BRANCH=12

# 编译参数
# LLVM_IAS=1 使用 LLVM 集成汇编器（修复 cortex-a77 不被 GNU assembler 识别）
# CLANG_TRIPLE 指定目标三元组
CUSTOM_CMDS:LLVM_IAS=1 CLANG_TRIPLE=aarch64-linux-gnu-

# === LXC and DOCKER ===
LXC_DOCKER=false
LXC_PATCH=false
ANDROID_PARANOID_NETWORK_OFF=false

# === KernelSU ===
ENABLE_KERNELSU=true
KERNELSU_TAG=v0.9.5

# === 额外配置 ===
DISABLE-LTO=true
DISABLE_CC_WERROR=true
ADD_KPROBES_CONFIG=true
ADD_OVERLAYFS_CONFIG=true

# === KVM ===
ENABLE_KVM=false

# === 缓存 ===
ENABLE_CCACHE=true

# === DTBO ===
NEED_DTBO=true

# === 构建 boot.img ===
BUILD_BOOT_IMG=true
SOURCE_BOOT_IMAGE=https://media.githubusercontent.com/media/typezhi/Xiaomi_Repository/refs/heads/main/mi10s/thyme_V14.0.6.0/boot.img