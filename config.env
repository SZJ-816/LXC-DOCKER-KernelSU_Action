# KernelSU Action 编译配置文件
# 用于为小米10S (thyme) 编译支持 EROFS + KernelSU 的内核
# 基于 crDroid 14.0 内核源码

# === 内核源码 ===
# 使用 crDroid 14.0 的 thyme 内核（已包含 EROFS 支持）
KERNEL_SOURCE=https://github.com/crdroidandroid/android_kernel_xiaomi_thyme
KERNEL_SOURCE_BRANCH=14.0
KERNEL_CONFIG=thyme_defconfig
KERNEL_IMAGE_NAME=Image
ARCH=arm64

# 编译参数
EXTRA_CMDS:LD=ld.lld
EXTRA_CMDT:LLVM=1
EXTRA_CMDU:LLVM_IAS=1

# === 编译方案 ===
# 'A' = clang+gcc 编译, 'B' = clang 编译
METHOD_OK=A

# === 编译器选择 ===
# true = 使用自定义 Clang, false = 使用 AOSP Clang
USE_CUSTOM_CLANG=true
CUT_PYTHON=false

# 自定义 Clang 源码
CUSTOM_CLANG_SOURCE=https://github.com/AOSP-12/prebuilts_clang_host_linux-x86_clang-r445002.git
CUSTOM_CLANG_BRANCH=12
CUSTOM_CMDS:CLANG_TRIPLE=aarch64-linux-gnu-

# AOSP Clang（如果 USE_CUSTOM_CLANG=false）
CLANG_BRANCH=android-gs-bluejay-5.10-android13
CLANG_VERSION=clang-r416183b

# === LXC and DOCKER ===
LXC_DOCKER=false
LXC_PATCH=false
ANDROID_PARANOID_NETWORK_OFF=false

# === KernelSU ===
ENABLE_KERNELSU=true
KERNELSU_TAG=v0.9.5

# === 额外配置 ===
# 关闭 LTO（避免编译错误）
DISABLE-LTO=true
# 关闭 CC_WERROR（避免 Kprobes 警告导致编译失败）
DISABLE_CC_WERROR=true
# 添加 Kprobes 配置（KernelSU 需要）
ADD_KPROBES_CONFIG=true
# 添加 overlayfs 配置（KernelSU 模块需要，虽然 defconfig 已有但确保）
ADD_OVERLAYFS_CONFIG=true

# === KVM ===
ENABLE_KVM=false

# === 缓存 ===
ENABLE_CCACHE=true

# === DTBO ===
NEED_DTBO=true

# === 构建 boot.img ===
BUILD_BOOT_IMG=true
# 使用 thyme V14.0.6.0 的 boot.img 作为源镜像
SOURCE_BOOT_IMAGE=https://media.githubusercontent.com/media/typezhi/Xiaomi_Repository/refs/heads/main/mi10s/thyme_V14.0.6.0/boot.img
